      "label": "Pay-to-win monetization",
      "keywords": ["pay to win", "p2w", "pay-to-win", "wallet warrior", "whales", "have to spend", "money grab", "cash grab", "greedy", "predatory", "gambling", "loot box", "lootbox", "gacha", "pity system"]
